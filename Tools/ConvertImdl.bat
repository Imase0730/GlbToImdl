@echo off
setlocal enabledelayedexpansion

REM --------------------------------------------------
REM ドロップされたファイルがあるか確認
REM --------------------------------------------------
if "%~1"=="" (
    echo ファイルをこのバッチにドラッグ＆ドロップしてください。
    pause
    exit /b
)

REM --------------------------------------------------
REM バッチファイルのある場所
REM --------------------------------------------------
set "TOOL_DIR=%~dp0"

REM --------------------------------------------------
REM ドロップされた全ファイルを処理
REM --------------------------------------------------
:LOOP

if "%~1"=="" goto END

REM フルパス＋ファイル名
set "INPUT_FILE=%~f1"

REM 拡張子
set "EXT=%~x1"

echo.
echo ==========================================
echo 変換中: !INPUT_NAME!
echo ==========================================

REM --------------------------------------------------
REM 拡張子でツール切り替え
REM --------------------------------------------------
if /I "!EXT!"==".obj" (
    echo ObjToImdl.exe を実行
    "%TOOL_DIR%ObjToImdl.exe" "!INPUT_FILE!"
)

if /I "!EXT!"==".glb" (
    echo GlbToImdl.exe を実行
    "%TOOL_DIR%GlbToImdl.exe" "!INPUT_FILE!"
)

REM --------------------------------------------------
REM 非対応拡張子
REM --------------------------------------------------
if /I not "!EXT!"==".obj" if /I not "!EXT!"==".glb" (
    echo 非対応ファイル: !INPUT_FILE!
)

shift
goto LOOP

:END

echo.
echo ==========================================
echo 全ての変換が完了しました
echo ==========================================
pause